/* Admin UI – clean SaaS cards */
.hc-admin-workspace__content{
  padding: 24px 24px 48px;
}
@media (max-width: 992px){
  .hc-admin-workspace__content{
    padding: 20px 16px 40px;
  }
}
@media (max-width: 576px){
  .hc-admin-workspace__content{
    padding: 16px 12px 32px;
  }
}

.hc-admin-wrapper{ padding-left:24px; padding-right:24px; }
.hc-admin-requests-page #main-content{ overflow: visible !important; }
.hc-admin-requests-page .container,
.hc-admin-requests-page .container-fluid{
  max-width: 100%;
}
.hc-admin-requests-page{
  --hc-admin-gap: 12px;
  --hc-nav-offset: 76px;
  --hc-requests-toolbar-height: 0px;
}
.hc-admin-grid{ display:grid; grid-template-columns: 1.55fr 1fr; gap:16px; align-items:start; }
@media (max-width: 992px){ .hc-admin-grid{ grid-template-columns: 1fr; } }


.hc-card{
  background: rgba(255,255,255,.92);
  border: 1px solid rgba(20,40,80,.12);
  border-radius: 16px;
  padding: 16px;
  box-shadow: 0 10px 25px rgba(0,0,0,.05);
}
.hc-admin-headerCard{
  padding: 14px 16px;
}
.hc-case-header .badge{
  font-weight: 600;
}
.hc-case-header .btn{
  white-space: nowrap;
}
.hc-admin-headerTop{
  margin-bottom: 8px;
}
.hc-admin-title{
  margin: 0;
  font-size: 1.45rem;
  line-height: 1.15;
  font-weight: 800;
}
.hc-card h3{ font-size:13px; letter-spacing:.2px; margin:0 0 10px; opacity:.85; }
.hc-row{ display:flex; justify-content:space-between; gap:12px; align-items:center; }
.hc-muted{ opacity:.72; font-size:13px; }
.hc-kpis{ display:grid; grid-template-columns: repeat(4,minmax(0,1fr)); gap:10px; }
@media (max-width: 768px){ .hc-kpis{ grid-template-columns: repeat(2,minmax(0,1fr)); } }
.hc-kpi{
  border-radius: 14px;
  border: 1px solid rgba(20,40,80,.10);
  padding: 10px 12px;
  background: rgba(245,248,255,.7);
}
.hc-kpi__label{ font-size:12px; opacity:.75; }
.hc-kpi__value{ font-size:18px; font-weight:800; margin-top:2px; }

.hc-tabs{ display:flex; gap:8px; flex-wrap:wrap; margin-top:8px; align-items:center; }
.hc-tab{
  border:1px solid rgba(20,40,80,.12);
  background: rgba(255,255,255,.9);
  border-radius: 999px;
  padding: 7px 12px;
  font-size: 13px;
  cursor:pointer;
}
.hc-tab[aria-current="true"]{
  border-color: rgba(20,40,80,.26);
  box-shadow: 0 10px 20px rgba(0,0,0,.06);
  font-weight: 800;
}

/* Compact header block */
.hc-admin-header{
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.hc-admin-topbar{
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px;
}

#hcAdminKpis{
  display: flex;
  gap: 8px;
  margin-top: 0;
}

#hcAdminKpis .hc-kpi-card{
  padding: 6px 12px;
  min-width: 70px;
  border-radius: 12px;
}

#hcAdminKpis .hc-kpi-card .hc-kpi__label{
  font-size: 11px;
}

#hcAdminKpis .hc-kpi-card .hc-kpi__value{
  font-size: 16px;
  margin-top: 2px;
}

.hc-admin-filters{
  display: flex;
  gap: 12px;
  align-items: center;
  flex-wrap: wrap;
}

.hc-admin-filters .hc-filter-status{
  width: 220px;
  max-width: 100%;
}

.hc-admin-filters .hc-filter-search{
  flex: 1 1 320px;
  min-width: 220px;
}

.hc-admin-filters .hc-filter-btn{
  white-space: nowrap;
}

.hc-admin-filters .hc-filter-deleted{
  margin: 0;
  white-space: nowrap;
}

.hc-admin-stickybar{
  position: sticky;
  top: var(--hc-nav-offset);
  z-index: 60;
  background: rgba(255,255,255,.98);
  backdrop-filter: blur(6px);
  border: 1px solid rgba(15,23,42,.08);
  border-radius: 14px;
  padding: 12px;
  box-shadow: 0 10px 30px rgba(2,6,23,.06);
}
.hc-requests-toolbar{
  position: static !important;
  top: auto !important;
  z-index: auto !important;
  background: rgba(255,255,255,.92);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}
#hcRequestsToolbar{
  position: static !important;
  top: auto !important;
  inset: auto !important;
  transform: none !important;
}

.hc-admin-stickybar + .hc-admin-tablewrap{
  margin-top: 12px;
}
.hc-admin-stickybar .btn{
  white-space: nowrap;
}
.hc-admin-stickybar .form-check{
  margin-bottom: 0;
}
.hc-bulkbar{
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px;
  padding-top: 8px;
  border-top: 1px solid rgba(15,23,42,.06);
}
.hc-bulkbar__count{
  min-width: 92px;
  font-size: 13px;
  color: rgba(15,23,42,.72);
}
.hc-bulkbar__select{
  width: 240px;
  max-width: 100%;
}
.hc-bulkbar__hint{
  margin-left: auto;
  font-size: 12px;
  color: rgba(15,23,42,.55);
}
.hc-quickchips{
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
  padding-top: 8px;
  border-top: 1px dashed rgba(15,23,42,.08);
}
.hc-quickchip{
  border: 1px solid rgba(15,23,42,.12);
  background: rgba(255,255,255,.96);
  color: rgba(15,23,42,.82);
  border-radius: 999px;
  padding: 7px 11px;
  font-size: 12px;
  line-height: 1;
  font-weight: 600;
  cursor: pointer;
}
.hc-quickchip:hover{
  border-color: rgba(59,130,246,.30);
  background: rgba(239,246,255,.7);
}
.hc-quickchip.is-active{
  background: rgba(37,99,235,.10);
  border-color: rgba(37,99,235,.30);
  color: rgba(29,78,216,.95);
}
.hc-quickchip--ghost{
  color: rgba(15,23,42,.58);
}

.hc-risk-overview{
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 8px;
}
.hc-risk-overview__item{
  border: 1px solid rgba(15,23,42,.10);
  border-radius: 10px;
  background: rgba(255,255,255,.96);
  padding: 8px 10px;
}
.hc-risk-overview__label{
  display: block;
  font-size: 12px;
  color: rgba(15,23,42,.72);
}
.hc-risk-overview__value{
  font-size: 16px;
  line-height: 1.1;
}
.hc-risk-overview__item--link{
  display: block;
  color: inherit;
  text-decoration: none;
}
.hc-risk-overview__item--link:hover{
  border-color: rgba(37,99,235,.30);
  box-shadow: 0 8px 20px rgba(2,6,23,.08);
}
.hc-case-detail-card--blockages{
  border-color: rgba(217, 119, 6, .24);
  background: linear-gradient(180deg, rgba(255,251,235,.96) 0%, rgba(255,255,255,.94) 100%);
  box-shadow: 0 10px 24px rgba(217,119,6,.08);
}
.hc-case-detail-card--blockages h3{
  color: rgba(146, 64, 14, .96);
}
.hc-case-detail-card--blockages .hc-blockage-list{
  padding-left: 1.1rem;
}
.hc-case-detail-card--blockages .hc-blockage-list li + li{
  margin-top: 4px;
}
.hc-risk-filters{
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
}
@media (max-width: 992px){
  .hc-risk-overview{
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

.table-responsive.hc-admin-tablewrap{
  overflow-x: auto;
  overflow-y: visible;
  scrollbar-gutter: stable both-edges;
}
@supports not (overflow: clip){
  .table-responsive.hc-admin-tablewrap{
    overflow-x: auto;
  }
}

.hc-live-card{
  padding-top: 12px;
  margin-top: 12px;
}
.hc-fold{
  margin-bottom: 16px;
}
.hc-insights{
  padding: 12px 14px;
}
.hc-insights #hcInsightsBody{
  margin-top: 10px;
}
.hc-insights .hc-health{
  margin-bottom: 10px;
}
.hc-live-card .hc-live-header{
  padding: 0;
}
.hc-live-card .hc-live-header h3{
  margin: 0;
}
.hc-live-card .hc-live-header .hc-muted{
  display: block;
  margin-top: 2px;
}

.hc-live-header{
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 0;
  background: transparent;
  padding: 0;
  font-weight: 700;
  cursor: pointer;
}

.hc-pilotage-grid{
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}
.hc-pilotage-card{
  background: rgba(255,255,255,.94);
  border: 1px solid rgba(15,23,42,.12);
  border-radius: 12px;
  padding: 14px;
}
.hc-pilotage-card h3{
  margin: 0 0 10px;
  font-size: 14px;
  font-weight: 700;
}
.hc-pilotage-card--link{
  display: block;
  color: inherit;
  text-decoration: none;
}
.hc-pilotage-card--link:hover{
  border-color: rgba(37,99,235,.28);
}
.hc-pilotage-table th{
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: .02em;
  color: rgba(15,23,42,.70);
}
.hc-pilotage-table td{
  font-size: 14px;
}
@media (max-width: 992px){
  .hc-pilotage-grid{
    grid-template-columns: 1fr;
  }
}
.hc-fold__head{
  position: relative;
  z-index: 1;
}
.hc-live-header__copy{
  display: inline-flex;
  flex-direction: column;
  align-items: flex-start;
  min-width: 0;
}
.hc-live-header__title{
  font-size: 13px;
  font-weight: 800;
  line-height: 1.15;
  color: rgba(15,23,42,.92);
}

.hc-live-chevron{
  transition: transform .16s ease;
}
.hc-fold__chev{
  font-size: 22px;
  opacity: .7;
}

.hc-live-header[aria-expanded="false"] .hc-live-chevron{
  transform: rotate(-90deg);
}
.hc-fold__head[aria-expanded="false"] .hc-fold__chev{
  transform: rotate(-90deg);
}

.hc-fold__subtitle{
  margin-top: 2px;
  opacity: .65;
  font-weight: 600;
}

.hc-live-body{
  margin-top: 8px;
}
.hc-fold__body{
  margin-top: 10px;
}

.hc-live-body.hc-live-hidden{
  display: none;
}

.hc-badge{
  display:inline-flex; align-items:center; gap:6px;
  border-radius:999px; padding:6px 10px; font-size:12px;
  border:1px solid rgba(20,40,80,.12);
  background: rgba(255,255,255,.95);
}

.hc-risk-cell{
  line-height: 1.25;
}
.hc-risk-cell strong{
  white-space: nowrap;
}

.hc-risk-badge{
  display: inline-block;
  padding: 4px 10px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.02em;
}

.hc-risk-badge--standard{
  background: #eef2ff;
  color: #334155;
}

.hc-risk-badge--attention{
  background: #fff7ed;
  color: #c2410c;
}

.hc-risk-badge--critical{
  background: #fef2f2;
  color: #b91c1c;
}
@media (max-width: 768px){
  .hc-risk-cell{
    font-size: 12px;
  }
}

.hc-activity-item{ border-top:1px solid rgba(20,40,80,.08); padding-top:10px; margin-top:10px; }
.hc-activity-title{ font-weight:800; font-size:13px; margin:0; }
.hc-activity-meta{ font-size:12px; opacity:.72; margin-top:2px; }

.hc-activity .hc-activity-item{
  border-top: 0;
  border-left: 2px solid rgba(148,163,184,.45);
  border-radius: 10px;
  padding-top: 12px;
  padding-left: 14px;
  margin-top: 0;
  margin-bottom: 10px;
}

.hc-signal{
  border: 1px solid rgba(148,163,184,.35);
  background: rgba(248,250,252,.8);
  border-radius: 10px;
  padding: 10px 12px;
}
.hc-signal__title{
  font-weight: 700;
  font-size: 14px;
}
.hc-signal__why{
  color: rgba(15,23,42,.72);
  font-size: 12px;
  margin-top: 2px;
}
.hc-signal--danger{
  border-color: rgba(239,68,68,.45);
  background: rgba(254,242,242,.85);
}
.hc-signal--warning{
  border-color: rgba(245,158,11,.45);
  background: rgba(255,251,235,.88);
}
.hc-signal--ok{
  border-color: rgba(34,197,94,.35);
  background: rgba(240,253,244,.88);
}
.hc-signal--info{
  border-color: rgba(59,130,246,.35);
  background: rgba(239,246,255,.9);
}

/* Admin requests focus-mode overrides for KPI + status blocks */
.hc-admin-requests-page .hc-health{
  margin-bottom: 12px;
  padding: 14px 18px;
  border-radius: 14px;
}
.hc-admin-requests-page .hc-health__label{
  font-size: 14px;
  margin-bottom: 2px;
}
.hc-admin-requests-page .hc-health__sub{
  font-size: 13px;
}
.hc-admin-requests-page .hc-health__value{
  font-size: 18px;
}
.hc-admin-requests-page .hc-ops-kpis{
  margin-bottom: 12px;
}
.hc-admin-requests-page .hc-ops-kpis__header{
  margin-bottom: 10px;
}
.hc-admin-requests-page .hc-ops-kpis .hc-h2{
  margin: 0;
  font-size: 1.05rem;
}
.hc-admin-requests-page .hc-ops-kpis__meta{
  font-size: 12px;
}
.hc-admin-requests-page .hc-ops-kpis__grid{
  gap: 10px;
}
.hc-admin-requests-page .hc-kpi-card{
  min-height: 86px;
  padding: 12px 14px;
  border-radius: 14px;
}
.hc-admin-requests-page .hc-kpi-value{
  font-size: 1.1rem;
  line-height: 1.1;
}
.hc-admin-requests-page .hc-kpi-label{
  font-size: 13px;
}
.hc-admin-requests-page .hc-kpi-sub{
  font-size: 12px;
}

.hc-sticky{ position: sticky; top: var(--hc-nav-offset, 84px); }
@media (max-width: 992px){ .hc-sticky{ position: static; } }

.hc-coordination-fold{
  border: 1px solid rgba(20,40,80,.12);
  border-radius: 14px;
  background: rgba(255,255,255,.92);
  box-shadow: 0 10px 25px rgba(0,0,0,.05);
  padding: 12px 14px;
}
.hc-coordination-fold > summary{
  list-style: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}
.hc-coordination-fold > summary::-webkit-details-marker{
  display: none;
}
.hc-coordination-fold > summary::after{
  content: "▾";
  color: rgba(15,23,42,.66);
  font-size: 14px;
  line-height: 1;
  transition: transform .15s ease;
}
.hc-coordination-fold:not([open]) > summary::after{
  transform: rotate(-90deg);
}

.hc-chip{
  display:inline-flex; align-items:center; gap:6px;
  padding:6px 10px;
  border-radius:999px;
  font-size:12px;
  border:1px solid rgba(20,40,80,.12);
  background: rgba(255,255,255,.95);
  white-space:nowrap;
}
.hc-chip--pos{ background: rgba(236,253,245,.9); border-color: rgba(16,185,129,.25); }
.hc-chip--neg{ background: rgba(248,250,252,.95); border-color: rgba(100,116,139,.25); }
.hc-chip__dot{
  width:8px; height:8px; border-radius:999px; display:inline-block;
  background: rgba(20,40,80,.35);
}
.hc-chip--pos .hc-chip__dot{ background: rgba(16,185,129,.9); }
.hc-chip--neg .hc-chip__dot{ background: rgba(100,116,139,.8); }

tr.hc-row-hot{ outline: 2px solid rgba(16,185,129,.18); outline-offset: -2px; border-radius: 10px; }

#hcCopyLinkBtn{
  margin-left:auto;
  min-width: 38px;
  width: 38px;
  padding-inline: 0;
  display: grid;
  place-items: center;
}
#hcCopyLinkBtn > span:first-child{
  width: 15px;
  height: 15px;
  border: 1.5px solid rgba(15,23,42,.45);
  border-radius: 4px;
  display: inline-block;
  position: relative;
}
#hcCopyLinkBtn > span:first-child::after{
  content:"";
  position:absolute;
  width: 15px;
  height: 15px;
  border: 1.5px solid rgba(15,23,42,.25);
  border-radius: 4px;
  left: 3px;
  top: -4px;
  background: transparent;
}

.hc-toast{
  position: fixed;
  right: 16px;
  bottom: 16px;
  z-index: 9999;
  background: rgba(20,40,80,.92);
  color: #fff;
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 14px;
  padding: 10px 12px;
  box-shadow: 0 12px 30px rgba(0,0,0,.18);
  font-size: 13px;
  display: flex;
  align-items: center;
  gap: 10px;
  opacity: 0;
  transform: translateY(8px);
  pointer-events: none;
  transition: opacity .18s ease, transform .18s ease;
}
.hc-toast--show{
  opacity: 1;
  transform: translateY(0);
}
.hc-toast__dot{
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: rgba(255,255,255,.75);
}
.hc-toast--ok .hc-toast__dot{ background: rgba(34,197,94,.95); }
.hc-toast--bad .hc-toast__dot{ background: rgba(248,113,113,.95); }

/* Copy-link micro feedback */
#hcCopyLinkBtn{ position: relative; }
#hcCopyLinkBtn .hc-copy-tick{
  position: absolute;
  right: -6px;
  top: -6px;
  width: 18px;
  height: 18px;
  border-radius: 999px;
  background: rgba(34,197,94,.95);
  color: #fff;
  display: grid;
  place-items: center;
  font-size: 12px;
  box-shadow: 0 10px 22px rgba(0,0,0,.18);
  opacity: 0;
  transform: scale(.85);
  pointer-events: none;
  transition: opacity .14s ease, transform .14s ease;
}
#hcCopyLinkBtn.hc-copy-ok .hc-copy-tick{
  opacity: 1;
  transform: scale(1);
}

tr[data-href]:hover td{
  background: #f5f8ff;
}

tr[data-owner-state="free"] td:first-child{
  box-shadow: inset 3px 0 0 rgba(37,99,235,.65);
}
tr[data-owner-state="mine"] td:first-child{
  box-shadow: inset 3px 0 0 rgba(34,197,94,.75);
}
tr[data-owner-state="taken"] td:first-child{
  box-shadow: inset 3px 0 0 rgba(148,163,184,.55);
}

tr[style*="display: none"] td { background: transparent !important; }

tr.hc-row-actionable td:first-child{
  position: relative;
}
tr.hc-row-actionable td:first-child::before{
  content:"";
  position:absolute;
  left: 0;
  top: 8px;
  bottom: 8px;
  width: 3px;
  border-radius: 999px;
  background: rgba(59,130,246,.35);
}

/* MEDIUM */
tr.hc-row-actionable[data-priority="MEDIUM"] td:first-child::before{
  background: rgba(59,130,246,.55);
}

/* HIGH */
tr.hc-row-actionable[data-priority="HIGH"] td:first-child::before{
  background: rgba(59,130,246,.85);
}

/* URGENT */
tr.hc-row-actionable[data-priority="URGENT"] td:first-child::before{
  background: rgba(239,68,68,.85);
}

.hc-admin-table{ table-layout: fixed; width:100%; }
.hc-admin-table th, .hc-admin-table td{
  vertical-align: top;
  overflow: hidden;
  text-overflow: ellipsis;
}
.hc-admin-table thead th{
  position: sticky;
  top: calc(var(--hc-nav-offset) + var(--hc-requests-toolbar-height) + 8px);
  z-index: 45;
  background: rgba(255,255,255,.96);
  backdrop-filter: blur(8px);
  box-shadow: inset 0 -1px 0 rgba(15,23,42,.08), 0 6px 18px rgba(2,6,23,.06);
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: .04em;
  color: rgba(15,23,42,.65);
  border-bottom: 1px solid rgba(15,23,42,.10);
}
.hc-requests-list{
  overflow: visible;
}

.hc-admin-table th{
  white-space: nowrap;
}

.hc-perf-kpi-row{
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}

.hc-perf-kpi{
  min-width: 180px;
  border-radius: 12px;
  border: 1px solid rgba(20,40,80,.10);
  background: rgba(245,248,255,.7);
  padding: 12px;
}

.hc-perf-kpi__label{
  opacity: .75;
  font-size: .85rem;
}

.hc-perf-kpi__value{
  font-size: 1.25rem;
  font-weight: 600;
}

.hc-perf-hint{
  opacity: .75;
  font-size: .85rem;
}

.hc-td-request{ overflow:hidden; }
.hc-req__title{
  font-weight: 650;
  line-height: 1.25;
  margin-bottom: 6px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.hc-req__meta{
  display:flex;
  flex-wrap: wrap;
  gap: 6px;
  align-items: center;
  color: rgba(15,23,42,.75);
  font-size: 12px;
  min-width: 0;
}
.hc-metaItem{
  max-width: 220px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.hc-dot{ opacity:.6; }
.hc-metaPills{
  display:flex;
  gap:6px;
  margin-left: 0;
  flex-wrap:wrap;
  flex-basis: 100%;
