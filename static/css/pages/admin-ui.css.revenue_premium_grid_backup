/* Revenue premium action menu */
.hc-action-menu {
  position: relative;
  display: inline-block;
}

.hc-action-menu > summary {
  list-style: none;
  cursor: pointer;
  border: 1px solid #cbd8ea;
  border-radius: 12px;
  padding: .55rem .85rem;
  background: #fff;
  font-weight: 800;
  color: #12365f;
  box-shadow: 0 8px 20px rgba(15, 35, 65, .08);
}

.hc-action-menu > summary::-webkit-details-marker {
  display: none;
}

.hc-action-menu-panel {
  position: absolute;
  right: 0;
  top: calc(100% + 8px);
  z-index: 50;
  min-width: 210px;
  padding: .55rem;
  border: 1px solid #d8e2ef;
  border-radius: 14px;
  background: #fff;
  box-shadow: 0 18px 45px rgba(15, 35, 65, .18);
  display: grid;
  gap: .35rem;
}

.hc-action-menu-panel a,
.hc-action-menu-panel button {
  width: 100%;
  justify-content: flex-start;
  text-align: left;
  border-radius: 10px;
  box-shadow: none;
}

.hc-action-menu-sep {
  height: 1px;
  background: #e6edf7;
  margin: .25rem 0;
}


