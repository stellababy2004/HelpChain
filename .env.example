# Professional leads (pilot) notifications
PRO_LEADS_NOTIFY_TO=contact@helpchain.live
# PRO_LEADS_NOTIFY_TO=dev-notifs@helpchain.live
PUBLIC_BASE_URL=https://helpchain.live
TRUST_PROXY_HEADERS=true
# PROXY_FIX_X_FOR=1
# PROXY_FIX_X_PROTO=1
# PROXY_FIX_X_HOST=1

# Metrics guardrail
METRICS_TOKEN=replace-with-long-random-token
HC_ENABLE_LEAK_TEST=0
# Comma-separated; optional. Example: 203.0.113.10,198.51.100.22
HC_LEAK_TEST_ALLOWLIST=
