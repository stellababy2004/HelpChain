{
  "version": 2,
  "builds": [
    {
      "src": "appy.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "appy.py"
    }
  ],
  "functions": {
    "appy.py": {
      "maxDuration": 30
    }
  },
  "env": {
    "PYTHONPATH": "."
  },
  "outputDirectory": ".",
  "installCommand": "pip install -r requirements.txt --no-cache-dir",
  "buildCommand": "echo 'Build completed'"
}
