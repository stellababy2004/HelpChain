# === HelpChain – Environment Variables ===
# ВНИМАНИЕ: НЕ commit-вайте този файл! Трябва да е в .gitignore

# Flask secret key (ЗАДЪЛЖИТЕЛНО сменете в production!)
SECRET_KEY=REPLACE_ME

# Database (остави празно за SQLite локално)
DATABASE_URL=

# --- Mail настройки (СМЕНЕТЕ преди production!) ---
# ВАЖНО: Никога не commit-вайте реални пароли!
MAIL_SERVER=smtp.zoho.eu
MAIL_PORT=465
MAIL_USE_SSL=True
MAIL_USE_TLS=False
MAIL_USERNAME=contact@helpchain.live
MAIL_PASSWORD=REPLACE_ME
MAIL_DEFAULT_SENDER=contact@helpchain.live

# --- Admin credentials (временни за тестване!) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_ME
ADMIN_EMAIL=contact@helpchain.live

# --- Optional services ---
HF_TOKEN=your_huggingface_token_here
OPENAI_API_KEY=REPLACE_ME
