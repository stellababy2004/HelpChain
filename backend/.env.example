# === HelpChain – Environment Variables ===
# ВНИМАНИЕ: НЕ commit-вайте този файл! Трябва да е в .gitignore

# App / Flask
FLASK_ENV=production
SECRET_KEY=change_me
# Explicit secret consumed by app.py (preferred). Replace with strong random value.
HELPCHAIN_SECRET_KEY=CHANGE_ME_STRONG_RANDOM
# JWT secret (required in staging/prod; do NOT rely on fallback)
JWT_SECRET_KEY=CHANGE_ME_LONG_RANDOM
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:you@example.com


# Postgres credentials (синхрон с реалната роля!)
POSTGRES_USER=helpchain
POSTGRES_PASSWORD=REPLACE_ME_DB_PASSWORD
POSTGRES_DB=helpchain
POSTGRES_HOST=db
POSTGRES_PORT=5432

# SQLAlchemy / App
DATABASE_URL=postgresql://helpchain:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Mail настройки (сменете преди production!)
MAIL_SERVER=smtp.zoho.eu
MAIL_PORT=465
MAIL_USE_SSL=True
MAIL_USE_TLS=False
MAIL_USERNAME=contact@helpchain.live
MAIL_PASSWORD=REPLACE_ME
MAIL_DEFAULT_SENDER=contact@helpchain.live

# Admin credentials (временни за тестване!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG
ADMIN_EMAIL=contact@helpchain.live

# Optional services
HF_TOKEN=your_huggingface_token_here
OPENAI_API_KEY=your_openai_api_key_here
JWT_SECRET_KEY=change_me_jwt_secret
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=AI_PROVIDER=ollama          # по избор, не е задължително
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
OPENAI_API_KEY=             # остави празно/изтрий, за да е изключен OpenAI


#adm pwd
$env:ADMIN_USER_PASSWORD = "REPLACE_ME_ADMIN_PASSWORD"

