# === HelpChain – Environment Variables ===
# ВНИМАНИЕ: НЕ commit-вайте този файл! Трябва да е в .gitignore

# App / Flask
FLASK_ENV=production
SECRET_KEY=change_me
# Explicit secret consumed by app.py (preferred). Replace with strong random value.
HELPCHAIN_SECRET_KEY=CHANGE_ME_STRONG_RANDOM

# Postgres credentials (синхрон с реалната роля!)
POSTGRES_USER=helpchain
POSTGRES_PASSWORD=NewStrong!Prod2025
POSTGRES_DB=helpchain
POSTGRES_HOST=db
POSTGRES_PORT=5432

# SQLAlchemy / App
DATABASE_URL=postgresql://helpchain:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Mail настройки (сменете преди production!)
MAIL_SERVER=smtp.zoho.eu
MAIL_PORT=465
MAIL_USE_SSL=True
MAIL_USE_TLS=False
MAIL_USERNAME=contact@helpchain.live
MAIL_PASSWORD=REPLACE_ME
MAIL_DEFAULT_SENDER=contact@helpchain.live

# Admin credentials (временни за тестване!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG
ADMIN_EMAIL=contact@helpchain.live

# Optional services
HF_TOKEN=your_huggingface_token_here
OPENAI_API_KEY=REPLACE_ME

#adm pwd
$env:ADMIN_USER_PASSWORD = "Admin12345!"