# CRITICAL: Exclude entire virtual environment directories
venv
.venv
venv_old

# Exclude the duplicate project directory
HelpChain.bg

# Exclude all Python compiled files and cache
**/*.pyc
**/*.pyo
**/*.pyd
**/__pycache__/
**/*.egg-info
**/*.dist-info

# Exclude Git and version control
.git
.gitignore
.gitattributes.txt

# Exclude development tools and cache
.pytest_cache
.ruff_cache
htmlcov
.coverage

# Exclude logs (including large log files)
*.log
helpchain*.log
sent_emails.txt
cookies.txt

# Exclude database files
instance
*.db
*.sqlite
*.sqlite3

# Exclude backups and old files
backups
alembic.backup*
old_db
migrations

# Exclude environment files
.env*

# Exclude documentation
*.md
.github
.pre-commit-config.yaml
ruff.toml
babel.cfg

# Exclude scripts
*.bat
scripts
run.helpchain.bat
start_*.bat
start_*.py

# Exclude duplicate directories
helpchain_backend

# IMPORTANT: Keep these Flask-required directories
# uploads - keep for file uploads
# logo - keep for branding
# static - REQUIRED for Flask static files (CSS, JS, images)
# templates - REQUIRED for Flask templates (HTML)
# email_templates - keep for email functionality

# Exclude temporary files
tmp_*.py
temp_app.py

# Exclude analytics files that might be large
performance_*.py
analytics_*.py
advanced_analytics.py
ai_service.py

# Exclude compressed files
*.zip
*.tar.gz
*.7z

# Exclude IDE files
.vscode
.idea
*.swp
*~

# Exclude OS files
.DS_Store
Thumbs.db
