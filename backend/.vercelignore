# Exclude virtual environments
venv/
.venv/
venv_old/

# Exclude Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Exclude Git
.git/
.gitignore
.gitattributes.txt

# Exclude development and testing files
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage
tests/
test_*.py
conftest.py
pytest.ini

# Exclude logs and temporary files
*.log
helpchain*.log
sent_emails.txt
cookies.txt
server.log

# Exclude database files
instance/
*.db
notifications.db

# Exclude backups and old files
backups/
alembic.backup*/
old_db/
migrations/

# Exclude configuration and environment files
.env*
.env.example
.env.prod
.env.prod.template
.env.gmail_test

# Exclude documentation and development files
*.md
.github/
.pre-commit-config.yaml
ruff.toml
babel.cfg

# Exclude scripts and batch files
*.bat
scripts/
run.helpchain.bat
start_*.bat
start_*.py

# Exclude duplicate project directories
HelpChain.bg/
helpchain_backend/

# Exclude uploads and temporary directories
uploads/
tmp_*.py
temp_app.py

# Exclude email templates and static assets that might be large
email_templates/
logo/
static/
templates/

# Exclude performance and analytics files that might contain large data
performance_*.py
performance_*.md
analytics_*.py
advanced_analytics.py
ai_service.py

# Exclude specific large files
backend.zip
.git.zip
