**/*.pyc
**/*.pyo
**/*.pyd
**/__pycache__/
**/*.egg-info
**/*.dist-info

# Exclude Git and version control
.git
.gitignore
.gitattributes.txt

# Exclude development tools and cache
.pytest_cache
.ruff_cache
htmlcov
.coverage

# Exclude logs (including large log files)
*.log
helpchain*.log
sent_emails.txt
cookies.txt

# Exclude database files
instance
*.db
*.sqlite
*.sqlite3

