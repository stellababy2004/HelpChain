msgid ""
"HelpChain ne remplace pas les structures existantes. La plateforme agit "
"comme un outil complémentaire permettant de faciliter la coordination entre "
"différents acteurs."
msgstr ""
"HelpChain ersetzt keine bestehenden Strukturen. Die Plattform fungiert als "
"ergänzendes Instrument zur Erleichterung der Koordinierung zwischen "
"verschiedenen Akteuren."

#: templates/faq.html:57
msgid "Les données personnelles sont-elles protégées ?"
msgstr "Sind personenbezogene Daten geschützt?"

#: templates/faq.html:58
msgid "Oui."
msgstr "Ja."

