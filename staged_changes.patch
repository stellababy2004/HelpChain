+                volunteer.created_at.strftime('%d.%m.%Y') }} {% else %} Няма
+                дата {% endif %}
+              </td>
+              <td>
+                <span class="status-badge status-active">Активен</span>
+              </td>
+              <td>
+                <div class="btn-group" role="group">
+                  <button
+                    class="btn btn-info-modern btn-modern btn-sm"
+                    onclick="viewVolunteer({{ volunteer.id }})"
+                    title="Виж детайли"
+                  >
+                    <i class="fas fa-eye"></i>
+                  </button>
+                  <button
+                    class="btn btn-warning-modern btn-modern btn-sm"
+                    onclick="editVolunteer({{ volunteer.id }})"
+                    title="Редактирай"
+                  >
+                    <i class="fas fa-edit"></i>
+                  </button>
+                  <button
+                    class="btn btn-danger-modern btn-modern btn-sm"
+                    onclick="deleteVolunteer({{ volunteer.id }}, '{{ volunteer.name }}')"
+                    title="Изтрий"
+                  >
+                    <i class="fas fa-trash"></i>
+                  </button>
+                </div>
+              </td>
+            </tr>
+            {% endfor %} {% else %}
+            <tr>
+              <td colspan="8" class="text-center py-5">
+                <i class="fas fa-users fa-3x text-muted mb-3"></i>
+                <h4 class="text-muted">Няма намерени доброволци</h4>
+                <p class="text-muted">
+                  {% if search or location_filter %} Няма доброволци, отговарящи
+                  на зададените критерии за търсене. {% else %} Все още няма
+                  регистрирани доброволци в системата. {% endif %}
+                </p>
+                <a
+                  href="{{ url_for('add_volunteer') }}"
+                  class="btn btn-success-modern btn-modern"
+                >
+                  <i class="fas fa-plus me-1"></i>Добави първия доброволец
+                </a>
+              </td>
+            </tr>
+            {% endif %}
+          </tbody>
+        </table>
+      </div>
+
+      <!-- Pagination -->
+      {% if total_pages > 1 %}
+      <div class="pagination-modern">
+        {% set start_page = [1, page - 2]|max %} {% set end_page = [total_pages,
+        page + 2]|min %} {% if page > 1 %}
+        <a
+          href="{{ url_for('admin_volunteers', page=page-1, search=search, location=location_filter, sort=sort_by, order=sort_order) }}"
+          class="page-link"
+        >
+          <i class="fas fa-chevron-left"></i>
+        </a>
+        {% endif %} {% for page_num in range(start_page, end_page + 1) %}
+        <a
+          href="{{ url_for('admin_volunteers', page=page_num, search=search, location=location_filter, sort=sort_by, order=sort_order) }}"
+          class="page-link {% if page_num == page %}active{% endif %}"
+        >
+          {{ page_num }}
+        </a>
+        {% endfor %} {% if page < total_pages %}
+        <a
+          href="{{ url_for('admin_volunteers', page=page+1, search=search, location=location_filter, sort=sort_by, order=sort_order) }}"
+          class="page-link"
+        >
+          <i class="fas fa-chevron-right"></i>
+        </a>
+        {% endif %}
+      </div>
+      {% endif %}
+
+      <!-- Results Info -->
+      <div class="text-center text-muted mt-3">
+        {% if volunteers %} Показани са {{ volunteers|length }} от общо {{
+        total_volunteers }} доброволци {% if search or location_filter %}
+        (филтрирани резултати) {% endif %} {% endif %}
+      </div>
+    </div>
+
+    <!-- Bootstrap JS -->
+    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
+
+    <!-- Custom JavaScript -->
+    <script>
+      // Theme Toggle Functionality
+      const themeToggle = document.getElementById("themeToggle");
+      const html = document.documentElement;
+      const themeIcon = themeToggle.querySelector("i");
+
+      // Load saved theme
+      const savedTheme = localStorage.getItem("theme") || "light";
+      html.setAttribute("data-theme", savedTheme);
+      updateThemeIcon(savedTheme);
+
+      themeToggle.addEventListener("click", () => {
+        const currentTheme = html.getAttribute("data-theme");
+        const newTheme = currentTheme === "light" ? "dark" : "light";
+
+        html.setAttribute("data-theme", newTheme);
+        localStorage.setItem("theme", newTheme);
+        updateThemeIcon(newTheme);
+      });
+
+      function updateThemeIcon(theme) {
+        themeIcon.className = theme === "light" ? "fas fa-moon" : "fas fa-sun";
+      }
+
+      // Volunteer Actions
+      function viewVolunteer(id) {
+        window.location.href = `/admin/volunteer/${id}`;
+      }
+
+      function editVolunteer(id) {
+        window.location.href = `/admin/volunteer/${id}/edit`;
+      }
+
+      function deleteVolunteer(id, name) {
+        if (
+          confirm(
+            `Сигурни ли сте, че искате да изтриете доброволеца "${name}"? Това действие е необратимо.`,
+          )
+        ) {
+          fetch(`/admin/volunteer/${id}/delete`, {
+            method: "POST",
+            headers: {
+              "Content-Type": "application/json",
+            },
+          })
+            .then((response) => response.json())
+            .then((data) => {
+              if (data.success) {
+                location.reload();
+              } else {
+                alert("Грешка при изтриване: " + data.message);
+              }
+            })
+            .catch((error) => {
+              console.error("Error:", error);
+              alert("Възникна грешка при изтриване на доброволеца");
+            });
+        }
+      }
+
+      function exportVolunteers() {
+        const format = prompt(
+          "Изберете формат за експорт (csv/json/pdf):",
+          "csv",
+        );
+        if (format) {
+          window.location.href = `/export_volunteers?format=${format}`;
+        }
+      }
+
+      // Logout function
+      function logout() {
+        if (
+          confirm(
+            "Сигурни ли сте, че искате да излезете от администраторския панел?",
+          )
+        ) {
+          const form = document.createElement("form");
+          form.method = "POST";
+          form.action = "/admin_logout";
+          document.body.appendChild(form);
+          form.submit();
+        }
+      }
+
+      // Initialize animations
+      document.addEventListener("DOMContentLoaded", function () {
+        const cards = document.querySelectorAll(
+          ".stats-card, .filters-section, .table-modern",
+        );
+        cards.forEach((card, index) => {
+          card.style.animationDelay = `${index * 0.1}s`;
+        });
+      });
+    </script>
+  </body>
+</html>
