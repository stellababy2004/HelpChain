+    <!-- Custom JavaScript -->
+    <script>
+      // Global variables
+      let trendsChart, categoryChart, geoChart, predictionChart;
+      let liveUpdateInterval;
+      let websocketClient;
+
+      // Load data from JSON scripts
+      const trendsData = JSON.parse(
+        document.getElementById("trendsData").textContent,
+      );
+      const categoryStats = JSON.parse(
+        document.getElementById("categoryStats").textContent,
+      );
+      const predictions = JSON.parse(
+        document.getElementById("predictions").textContent,
+      );
+
+      // Initialize charts when page loads
+      document.addEventListener("DOMContentLoaded", function () {
+        initializeCharts();
+        initializeWebSocket();
+        startLiveUpdates();
+      });
+
+      function initializeWebSocket() {
+        // Initialize WebSocket connection for real-time analytics
+        websocketClient = new HelpChainWebSocket(
+          window.location.protocol + "//" + window.location.host,
+        );
+
+        // Get user info from session (passed from server)
+        const userId = '{{ session.get("admin_user_id", "admin") }}';
+        const userName = '{{ session.get("admin_username", "Admin") }}';
+
+        websocketClient
+          .connect({
+            userId: userId,
+            userName: userName,
+            userType: "admin",
+          })
+          .then(() => {
+            console.log("Connected to WebSocket for analytics");
+
+            // Join analytics room
+            websocketClient.joinAnalyticsRoom("analytics");
+
+            // Subscribe to personalized analytics updates
+            websocketClient.subscribeAnalytics([
+              "requests",
+              "volunteers",
+              "performance",
+            ]);
+
+            // Set up event listeners for real-time updates
+            setupWebSocketListeners();
+          })
+          .catch((error) => {
+            console.error("Failed to connect to WebSocket:", error);
+            // Fallback to polling if WebSocket fails
+            console.log("Falling back to polling for analytics updates");
+          });
+      }
+
+      function setupWebSocketListeners() {
+        // Listen for analytics updates
+        websocketClient.on("analytics_update", (data) => {
+          console.log("Received analytics update:", data);
+          updateChartsWithRealtimeData(data);
+        });
+
+        // Listen for live metrics updates
+        websocketClient.on("live_metrics_update", (data) => {
+          console.log("Received live metrics update:", data);
+          updateKPIsWithRealtimeData(data);
+        });
+
+        // Listen for analytics subscription confirmation
+        websocketClient.on("analytics_subscribed", (data) => {
+          console.log("Analytics subscription confirmed:", data);
+        });
+
+        // Handle connection status
+        websocketClient.on("connected", (data) => {
+          console.log("WebSocket connected:", data);
+          updateConnectionStatus(true);
+        });
+
+        websocketClient.on("disconnect", () => {
+          console.log("WebSocket disconnected");
+          updateConnectionStatus(false);
+        });
+      }
+
+      function updateConnectionStatus(connected) {
+        const liveIndicator = document.querySelector(".live-indicator");
