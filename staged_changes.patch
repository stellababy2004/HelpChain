+            text: `Прогноза за натоварване (${data.prediction_period_hours} часа)`,
+          },
+        },
+      },
+    });
+  }
+
+  // Render insights and recommendations
+  function renderInsights(data) {
+    // Regional insights
+    const regionalInsightsEl = document.getElementById("regionalInsights");
