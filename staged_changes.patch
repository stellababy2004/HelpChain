+    } else {
+      regionalInsightsEl.innerHTML = regionalInsights
+        .map(
+          (insight) => `
+      <div class="alert alert-${getSeverityClass(insight.severity)} mb-2">
+        <strong>${insight.region}:</strong> ${insight.insight}
+      </div>
+    `,
+        )
+        .join("");
+    }
+
+    // Recommendations
+    const recommendationsEl = document.getElementById("recommendations");
+    const recommendations = data.recommendations || [];
+
+    if (recommendations.length === 0) {
+      recommendationsEl.innerHTML =
+        '<p class="text-muted">Няма налични препоръки</p>';
+    } else {
+      recommendationsEl.innerHTML = recommendations
+        .map(
+          (rec) => `
+      <div class="d-flex align-items-center mb-2">
+        <i class="fas fa-check-circle text-success me-2"></i>
+        <span>${rec}</span>
+      </div>
+    `,
+        )
+        .join("");
+    }
+
+    // Risk assessment
+    const riskEl = document.getElementById("riskAssessment");
+    const risks = data.risk_assessment || [];
+
+    if (risks.length === 0) {
+      riskEl.innerHTML =
+        '<p class="text-muted">Няма идентифицирани рискове</p>';
+    } else {
+      riskEl.innerHTML = risks
+        .map(
+          (risk) => `
+      <div class="alert alert-${getRiskClass(risk.level)} mb-2">
+        <strong>${risk.level.toUpperCase()}:</strong> ${risk.description}
+      </div>
+    `,
+        )
+        .join("");
+    }
+  }
+
+  // Helper functions
+  function getSeverityClass(severity) {
+    const classes = {
+      high: "danger",
+      medium: "warning",
+      low: "info",
+    };
+    return classes[severity] || "secondary";
+  }
+
+  function getRiskClass(level) {
+    const classes = {
+      high: "danger",
+      medium: "warning",
+      low: "success",
+    };
+    return classes[level] || "secondary";
+  }
+
+  // Refresh all predictions
+  function refreshPredictions() {
+    updateRegionalForecast();
+    updateWorkloadPrediction();
+    updateInsights();
+  }
+
+  // Show model information
+  async function showModelInfo() {
+    const modal = new bootstrap.Modal(
+      document.getElementById("modelInfoModal"),
+    );
+    modal.show();
+
+    try {
+      const response = await fetch("/api/predictive/model-info");
+      const data = await response.json();
+
+      if (data.error) {
+        document.getElementById("modelInfoContent").innerHTML =
+          '<div class="alert alert-danger">Грешка при зареждане на информацията за моделите</div>';
+        return;
+      }
+
+      const content = `
+      <div class="row">
+        <div class="col-md-6">
+          <h6>Модел за регионално търсене</h6>
+          <ul class="list-unstyled">
+            <li><strong>Тип:</strong> ${data.regional_demand_model.type}</li>
+            <li><strong>Характеристики:</strong> ${data.regional_demand_model.features.join(
+              ", ",
+            )}</li>
+            <li><strong>Хоризонт:</strong> ${
+              data.regional_demand_model.prediction_horizon
+            }</li>
+            <li><strong>Последно обучение:</strong> ${new Date(
+              data.regional_demand_model.last_trained,
+            ).toLocaleString("bg-BG")}</li>
+          </ul>
+        </div>
+        <div class="col-md-6">
+          <h6>Модел за натоварване</h6>
+          <ul class="list-unstyled">
+            <li><strong>Тип:</strong> ${
+              data.workload_prediction_model.type
+            }</li>
+            <li><strong>Характеристики:</strong> ${data.workload_prediction_model.features.join(
+              ", ",
+            )}</li>
+            <li><strong>Хоризонт:</strong> ${
+              data.workload_prediction_model.prediction_horizon
+            }</li>
+            <li><strong>Последно обучение:</strong> ${new Date(
+              data.workload_prediction_model.last_trained,
+            ).toLocaleString("bg-BG")}</li>
+          </ul>
+        </div>
+      </div>
+      <hr>
+      <h6>Източници на данни</h6>
+      <ul>
+        ${data.data_sources.map((source) => `<li>${source}</li>`).join("")}
+      </ul>
+      <p class="text-muted mt-2">
+        <strong>Честота на обновяване:</strong> ${data.update_frequency}<br>
+        <strong>Резервна стратегия:</strong> ${data.fallback_strategy}
+      </p>
+    `;
+
+      document.getElementById("modelInfoContent").innerHTML = content;
+    } catch (error) {
+      document.getElementById("modelInfoContent").innerHTML =
+        '<div class="alert alert-danger">Грешка при зареждане на информацията</div>';
+    }
+  }
+
+  // Auto-refresh every 5 minutes
+  setInterval(refreshPredictions, 5 * 60 * 1000);
+</script>
