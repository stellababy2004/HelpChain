+<script>
+  let regionalDemandChart = null;
+  let workloadChart = null;
+
+  // Initialize charts and data on page load
+  document.addEventListener("DOMContentLoaded", function () {
+    updateRegionalForecast();
+    updateWorkloadPrediction();
