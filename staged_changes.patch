+name: CI – Lint • Security • Tests
+
+on:
+  push:
+    branches: [ main ]
+  pull_request:
+    branches: [ main ]
+  workflow_dispatch:
+
+permissions:
+  contents: read
+
+jobs:
+  build-test:
+    runs-on: ubuntu-latest
+    timeout-minutes: 20
+    strategy:
+      fail-fast: false
+      matrix:
+        python-version: ["3.11", "3.12"]
+
+    steps:
+      - name: Checkout
+        uses: actions/checkout@v5
+
+      - name: Set up Python ${{ matrix.python-version }}
+        uses: actions/setup-python@v5
+        with:
+          python-version: ${{ matrix.python-version }}
+          cache: "pip"
+
+      - name: Install dependencies
+        run: |
+          python -m pip install --upgrade pip
+          if [ -f requirements-dev.txt ]; then
+            pip install -r requirements-dev.txt
+          fi
+          if [ -f requirements.txt ]; then
+            pip install -r requirements.txt
+          fi
+          # ensure tools even if не са в requirements
+          pip install ruff black bandit pytest
+
+      - name: Ruff Lint
+        run: ruff check .
+
+      - name: Black (check only)
+        run: black --check .
+
+      - name: Bandit Security Scan
+        run: |
+          bandit -r . -x tests,.venv,venv,node_modules,frontend --severity-level medium --exit-zero
+        # --exit-zero за да не блокира dev; махни го, ако искаш да fail-ва при находки
+
+      - name: Pytest
+        run: |
+          pytest -v --maxfail=1 --disable-warnings --junitxml=pytest-report.xml
+        continue-on-error: false
+
+      - name: Upload Pytest Report
+        if: always()
+        uses: actions/upload-artifact@v4
+        with:
+          name: pytest-report-${{ matrix.python-version }}
+          path: pytest-report.xml
