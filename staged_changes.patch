+      },
+      options: {
+        responsive: true,
+        maintainAspectRatio: false,
+        scales: {
+          x: {
+            type: "time",
+            time: {
+              unit: "hour",
+              displayFormats: {
+                hour: "HH:mm",
+              },
+            },
+            title: {
+              display: true,
+              text: "Време",
+            },
+          },
+          y: {
+            beginAtZero: true,
+            title: {
+              display: true,
+              text: "Брой заявки",
+            },
+          },
