+        assert (
+            "подозрително съдържание" in response_text
+            or "suspicious content" in response_text.lower()
+        )
+        # Потребителският input не трябва да се изпълнява като HTML
+        assert xss_payload not in response_text.replace("&lt;", "<").replace(
