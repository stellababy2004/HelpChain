+
+  // Update regional demand forecast
+  async function updateRegionalForecast() {
+    const region = document.getElementById("regionSelect").value;
+    const days = document.getElementById("daysAhead").value;
+
+    try {
+      const response = await fetch(
+        `/api/predictive/regional-demand?region=${region}&days=${days}`,
+      );
+      const data = await response.json();
+
+      if (data.error) {
+        console.error("Error loading regional forecast:", data.error);
+        return;
+      }
+
+      renderRegionalDemandChart(data);
+    } catch (error) {
+      console.error("Error updating regional forecast:", error);
+    }
+  }
+
+  // Update workload prediction
+  async function updateWorkloadPrediction() {
+    const hours = document.getElementById("hoursAhead").value;
+
+    try {
+      const response = await fetch(`/api/predictive/workload?hours=${hours}`);
+      const data = await response.json();
+
+      if (data.error) {
+        console.error("Error loading workload prediction:", data.error);
+        return;
+      }
+
+      renderWorkloadChart(data);
+    } catch (error) {
+      console.error("Error updating workload prediction:", error);
+    }
+  }
+
+  // Update insights and recommendations
+  async function updateInsights() {
+    try {
+      const response = await fetch("/api/predictive/insights");
+      const data = await response.json();
+
+      if (data.error) {
+        console.error("Error loading insights:", data.error);
+        return;
+      }
+
+      renderInsights(data);
+    } catch (error) {
+      console.error("Error updating insights:", error);
+    }
+  }
+
+  // Render regional demand chart
+  function renderRegionalDemandChart(data) {
+    const ctx = document.getElementById("regionalDemandChart").getContext("2d");
+
+    if (regionalDemandChart) {
+      regionalDemandChart.destroy();
+    }
+
+    const regions = data.regions || {};
+    const datasets = [];
+    const colors = ["#FF6384", "#36A2EB", "#FFCE56", "#4BC0C0", "#9966FF"];
+
+    let colorIndex = 0;
+    for (const [regionName, regionData] of Object.entries(regions)) {
+      const forecast = regionData.forecast || [];
+      const predictedValues = forecast.map((item) => ({
+        x: new Date(item.date),
+        y: item.predicted_requests,
+      }));
+
+      datasets.push({
+        label: regionName,
+        data: predictedValues,
+        borderColor: colors[colorIndex % colors.length],
+        backgroundColor: colors[colorIndex % colors.length] + "20",
+        fill: false,
+        tension: 0.4,
+      });
+
+      colorIndex++;
+    }
+
+    regionalDemandChart = new Chart(ctx, {
+      type: "line",
+      data: {
+        datasets: datasets,
+      },
+      options: {
+        responsive: true,
+        maintainAspectRatio: false,
+        scales: {
+          x: {
+            type: "time",
+            time: {
+              unit: "day",
+              displayFormats: {
+                day: "MMM dd",
+              },
+            },
+            title: {
+              display: true,
+              text: "Дата",
+            },
+          },
+          y: {
+            beginAtZero: true,
+            title: {
+              display: true,
+              text: "Прогнозирани заявки",
+            },
+          },
+        },
+        plugins: {
+          title: {
+            display: true,
+            text: `Прогноза за търсене по региони (${data.forecast_period_days} дни)`,
+          },
+          legend: {
+            display: true,
+            position: "top",
+          },
+        },
+      },
+    });
+  }
+
+  // Render workload chart
+  function renderWorkloadChart(data) {
+    const ctx = document.getElementById("workloadChart").getContext("2d");
+
+    if (workloadChart) {
+      workloadChart.destroy();
+    }
+
+    const predictions = data.predictions || [];
+    const chartData = predictions.map((item) => ({
+      x: new Date(item.timestamp),
+      y: item.predicted_requests,
+    }));
+
+    workloadChart = new Chart(ctx, {
+      type: "line",
+      data: {
+        datasets: [
+          {
+            label: "Прогнозирани заявки",
+            data: chartData,
+            borderColor: "#36A2EB",
