{
  "version": 2,
  "env": {
    "PYTHONPATH": "_vendor:."
  },
  "routes": [
    { "src": "^/$", "dest": "/api/root.js" },
    { "src": "^/health$", "dest": "/public/health/index.html" },
    { "src": "^/admin/login$", "dest": "/public/admin/login/index.html" },
    { "handle": "filesystem" },
    { "src": "^/api/_health$", "dest": "/api/_health.js" },
    { "src": "^/api/analytics$", "dest": "/api/analytics.js" },
    { "src": "^(.*)$", "dest": "/api/index.py" }
  ]
}
