{
  "version": 2,
  "env": { "PYTHONPATH": "_vendor:." },
  "builds": [
    { "src": "api/**/*.py", "use": "@vercel/python" },
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/api/_health$", "dest": "/api/_health.js" },
    { "src": "^/health$", "dest": "/api/_health.js" },
    { "src": "^/api/analytics$", "dest": "/api/analytics.js" },
    { "src": "^/favicon.ico$", "dest": "/api/favicon.js" },
    { "src": "^/favicon.png$", "dest": "/api/favicon.js" },
    { "src": "^/api/root$", "dest": "/api/root.js" },
    { "src": "^/$", "dest": "/api/root.js" },

    { "src": "^/admin/login$", "dest": "/api/index.py", "methods": ["GET", "POST"] },
    { "src": "^/admin_login$", "dest": "/api/index.py", "methods": ["GET", "POST"] },
    { "src": "^/admin/(.*)$", "dest": "/api/index.py", "methods": ["GET", "POST"] },
    { "src": "^/(admin/.*)$", "dest": "/api/index.py", "methods": ["GET", "POST"] },
    { "src": "^/submit_request$", "dest": "/api/index.py", "methods": ["GET", "POST"] },

    { "handle": "filesystem" },

    { "src": "/.*", "status": 404, "dest": "/404" }
  ]
}
