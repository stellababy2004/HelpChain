{
  "version": 2,
  "builds": [
    {
      "src": "run.py",
      "use": "@vercel/python",
      "config": {
        "installCommand": "python -m pip install -r requirements.txt --target vendor"
      }
    }
  ],
  "routes": [
    {
      "src": "(.*)",
      "dest": "run.py"
    }
  ],
  "env": {
    "PYTHONPATH": "."
  }
}
